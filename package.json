{
  "name": "issue-dinner",
  "version": "0.1.0",
  "description": "Process Jira vertical-slice issues with the Cursor TypeScript SDK",
  "type": "module",
  "bin": {
    "issue-dinner": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.13",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "commander": "^13.1.0",
    "effect": "^3.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
