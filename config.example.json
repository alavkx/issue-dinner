{
  "model": "composer-2.5",
  "settingSources": ["project"],
  "requireVerify": true,
  "serveVerifyGate": "inner",
  "requireHandoffTests": true,
  "stackAuthor": "alavoie",
  "stackBaseOverride": "alavoie/cpd-635-user-event-log",
  "graphiteTrunk": "main",
  "blockerPolicy": "strict",
